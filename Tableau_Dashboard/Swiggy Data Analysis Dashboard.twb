      <column caption='Average Order Value' datatype='real' name='[Calculation_899594079793176579]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_899594079792816128]/[Calculation_899594079792963585]' />
      </column>
      <column caption='Revenue Growth' datatype='real' name='[Calculation_899594079793561604]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([Price (INR)])-LOOKUP(sum([Price (INR)]),-1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Growth %' datatype='real' name='[Calculation_899594079794282501]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(sum([Price (INR)])-LOOKUP(sum([Price (INR)]),-1))/LOOKUP(sum([Price (INR)]),-1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Month' datatype='integer' name='[Calculation_899594079808237574]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MONTH([Order Date])' />
      </column>
      <column caption='color' datatype='string' name='[Calculation_899594079855267849]' role='measure' type='nominal'>
